    }
    .step-actions .left { display: flex; gap: 0.75rem; }

    /* Summary sidebar */
    .summary-aside {
      position: sticky; top: 7rem;
      border: 1px solid var(--rule);
      border-radius: var(--r-sm);
      background: var(--bg-elev);
      padding: 2rem 1.75rem;
    }
    .summary-aside h4 {
      font-family: var(--font-mono);
      font-size: 0.7rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--ink-muted);
      font-weight: 400;
      margin-bottom: 1.25rem;
    }
    .summary-aside .sa-row {
      padding: 0.85rem 0;
      border-top: 1px solid var(--rule);
      display: grid;
      gap: 0.25rem;
    }
    .summary-aside .sa-row .k {
      font-family: var(--font-mono);
      font-size: 0.64rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--ink-muted);
    }
    .summary-aside .sa-row .v { font-family: var(--font-body); font-size: 0.95rem; color: var(--ink); }
    .summary-aside .sa-row .v.empty { color: var(--ink-muted); font-style: italic; }
    .summary-aside .foot {
      margin-top: 1.5rem;
      padding-top: 1.25rem;
      border-top: 1px solid var(--rule);
      font-family: var(--font-mono);
      font-size: 0.68rem;
      letter-spacing: 0.06em;
      color: var(--ink-muted);
      line-height: 1.6;
    }

    /* Success */
    .success {
      text-align: center;
      padding: 3rem 1rem;
      border: 1px solid var(--rule);
      border-radius: var(--r-sm);
      background: var(--bg-elev);
    }
    .success .mark-big {
      width: 56px; height: 56px;
      border: 1px solid var(--accent);
