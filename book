  <style>
    .book-wrap {
      max-width: var(--max-w);
      margin: 0 auto;
      padding: 4rem var(--container-pad);
      display: grid;
      grid-template-columns: 1fr 360px;
      gap: 4rem;
      align-items: start;
    }
    .book-main { min-height: 600px; }
    .book-head {
      margin-bottom: 3rem;
      padding-bottom: 2rem;
      border-bottom: 1px solid var(--rule);
    }
    .book-head .bread {
      font-family: var(--font-mono);
      font-size: 0.72rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--ink-muted);
      margin-bottom: 1.5rem;
    }
    .book-head h1 { font-size: clamp(2.4rem, 4.5vw, 3.6rem); max-width: 16ch; margin-bottom: 1rem; line-height: 1; }
    .book-head p { max-width: 48ch; font-size: 1rem; }

    /* Stepper */
    .stepper {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 0;
      border-top: 1px solid var(--rule);
      border-bottom: 1px solid var(--rule);
      margin-bottom: 3rem;
    }
    .stepper .st {
      padding: 1.25rem 1.5rem;
      border-right: 1px solid var(--rule);
      font-family: var(--font-mono);
      font-size: 0.72rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--ink-muted);
      display: flex; gap: 0.75rem; align-items: baseline;
      transition: all 180ms ease;
    }
    .stepper .st:last-child { border-right: 0; }
    .stepper .st.active { background: var(--ink); color: var(--on-contrast); }
    .stepper .st.done { color: var(--accent); }
    .stepper .st .n { font-family: var(--font-display); font-size: 1.1rem; }

    /* Form */
    .form-step { display: none; }
