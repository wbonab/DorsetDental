<script>
(function(){
  // ---- Where booking enquiries are sent ----------------------------------
  // Replace BOOKING_ENDPOINT with a Formspree/Web3Forms URL when ready.
  // While it's null the form opens the patient's mail client (mailto:) as a fallback.
  const BOOKING_INBOX    = 'brightbluedental@gmail.com';
  const BOOKING_ENDPOINT = null; // e.g. 'https://formspree.io/f/xxxxxxx'
  // ------------------------------------------------------------------------

  const form = document.getElementById('bookForm');
  const steps = form.querySelectorAll('.form-step');
  const stepperItems = document.querySelectorAll('#stepper .st');
  const nextBtn = document.getElementById('nextBtn');
  const backBtn = document.getElementById('backBtn');
  const stepActions = document.getElementById('stepActions');
  let cur = 1;

  const data = { treatment: '', date: '', time: '' };

  function showStep(n) {
    cur = n;
    steps.forEach(s => s.classList.toggle('active', Number(s.dataset.step) === n));
    stepperItems.forEach(s => {
      const sn = Number(s.dataset.step);
      s.classList.toggle('active', sn === n);
      s.classList.toggle('done', sn < n && n < 5);
    });
    backBtn.style.display = (n === 1 || n === 5) ? 'none' : 'inline-flex';
    if (n === 5) {
      stepActions.style.display = 'none';
    } else {
      stepActions.style.display = 'flex';
      nextBtn.innerHTML = n === 4 ? 'Confirm booking <span class="arr">→</span>' : 'Continue <span class="arr">→</span>';
    }
    if (n === 4) populateReview();
  }

  function validateStep(n) {
    if (n === 1) {
      const required = ['firstName','lastName','email','phone'];
      for (const name of required) {
        const el = form.elements[name];
        if (!el.value.trim()) { el.focus(); el.style.borderColor = 'oklch(55% 0.15 25)'; return false; }
        el.style.borderColor = '';
      }
      return true;
    }
    if (n === 2) {
      if (!form.elements['treatment'].value) { alert('Please select a treatment option.'); return false; }
      return true;
    }
    if (n === 3) {
      if (!data.date || !data.time) { alert('Please select a date and time.'); return false; }
      return true;
    }
    return true;
  }

  function updateSidebar() {
    const fn = form.elements['firstName']?.value || '';
    const ln = form.elements['lastName']?.value || '';
    const nameEl = document.querySelector('[data-sa="name"]');
    const txEl = document.querySelector('[data-sa="treatment"]');
    const dtEl = document.querySelector('[data-sa="datetime"]');
    if (fn || ln) { nameEl.textContent = (fn + ' ' + ln).trim(); nameEl.classList.remove('empty'); }
    if (data.treatment) { txEl.textContent = data.treatment; txEl.classList.remove('empty'); }
    if (data.date && data.time) {
      dtEl.textContent = formatDate(data.date) + ' · ' + data.time;
      dtEl.classList.remove('empty');
    }
  }

  function populateReview() {
    updateSidebar();
    const fn = form.elements['firstName']?.value || '';
    const ln = form.elements['lastName']?.value || '';
    document.querySelector('[data-field="name"]').textContent = (fn + ' ' + ln).trim() || '—';
    document.querySelector('[data-field="email"]').textContent = form.elements['email']?.value || '—';
    document.querySelector('[data-field="phone"]').textContent = form.elements['phone']?.value || '—';
    document.querySelector('[data-field="treatment"]').textContent = data.treatment || '—';
    document.querySelector('[data-field="datetime"]').textContent =
      (data.date && data.time) ? (formatDate(data.date) + ' at ' + data.time) : '—';
    document.querySelector('[data-field="notes"]').textContent = form.elements['notes']?.value || '—';
  }

  function collectBookingPayload(ref) {
    const fn = form.elements['firstName']?.value || '';
    const ln = form.elements['lastName']?.value || '';
    return {
      ref,
      name: (fn + ' ' + ln).trim(),
      email: form.elements['email']?.value || '',
      phone: form.elements['phone']?.value || '',
      treatment: data.treatment || '',
      datetime: (data.date && data.time) ? (formatDate(data.date) + ' at ' + data.time) : '',
      notes: form.elements['notes']?.value || ''
    };
  }

  function submitBooking(ref) {
    const p = collectBookingPayload(ref);
    // 1) Backend / form service path (preferred when configured)
    if (BOOKING_ENDPOINT) {
      try {
        fetch(BOOKING_ENDPOINT, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify({ _to: BOOKING_INBOX, _subject: 'New booking enquiry · ' + ref, ...p })
        });
      } catch(e) { /* swallow — confirmation already shown */ }
      return;
    }
    // 2) mailto fallback — opens the patient's email client pre-filled to William
    const subject = 'New booking enquiry · ' + ref;
    const body =
      'Booking reference: ' + ref + '\n' +
      'Name:      ' + p.name + '\n' +
      'Email:     ' + p.email + '\n' +
      'Phone:     ' + p.phone + '\n' +
      'Treatment: ' + p.treatment + '\n' +
      'Requested: ' + p.datetime + '\n\n' +
      'Notes:\n' + (p.notes || '(none)') + '\n';
    const href = 'mailto:' + BOOKING_INBOX +
                 '?subject=' + encodeURIComponent(subject) +
                 '&body=' + encodeURIComponent(body);
    // Open in a new tab so we don't navigate away from the confirmation screen
    window.open(href, '_blank');
  }

  nextBtn.addEventListener('click', () => {
    if (!validateStep(cur)) return;
    if (cur === 2) data.treatment = form.elements['treatment'].value;
    updateSidebar();
    if (cur === 4) {
      const ref = 'BDI-' + (Math.floor(Math.random() * 9000) + 1000);
      document.getElementById('refCode').textContent = ref;
      submitBooking(ref);
      showStep(5);
      return;
    }
    showStep(cur + 1);
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });

  backBtn.addEventListener('click', () => {
    if (cur > 1) { showStep(cur - 1); window.scrollTo({ top: 0, behavior: 'smooth' }); }
  });

  // Calendar
  const monthLabel = document.getElementById('monthLabel');
  const calGrid = document.getElementById('calGrid');
  const slotLabel = document.getElementById('slotLabel');
  const slotGrid = document.getElementById('slotGrid');
  let viewDate = new Date();
  viewDate.setDate(1);

  const months = ['January','February','March','April','May','June','July','August','September','October','November','December'];

  function renderCal() {
    const y = viewDate.getFullYear();
    const m = viewDate.getMonth();
    monthLabel.textContent = months[m] + ' ' + y;
    calGrid.innerHTML = '';
    const first = new Date(y, m, 1);
    const offset = (first.getDay() + 6) % 7; // Mon=0
    const daysInMonth = new Date(y, m + 1, 0).getDate();
    const today = new Date(); today.setHours(0,0,0,0);
    for (let i = 0; i < offset; i++) {
      const b = document.createElement('button');
      b.className = 'empty'; b.disabled = true; b.type = 'button';
      calGrid.appendChild(b);
    }
    for (let d = 1; d <= daysInMonth; d++) {
      const b = document.createElement('button');
      b.type = 'button';
      b.textContent = d;
      const date = new Date(y, m, d);
      const iso = date.toISOString().slice(0,10);
      const dow = date.getDay();
      const isPast = date < today;
      const isSunday = dow === 0;
      if (isPast || isSunday) b.disabled = true;
      if (data.date === iso) b.classList.add('sel');
      b.addEventListener('click', () => {
        data.date = iso; data.time = '';
        renderCal(); renderSlots();
      });
      calGrid.appendChild(b);
    }
  }

  function renderSlots() {
    if (!data.date) {
      slotLabel.textContent = 'Select a date';
      slotGrid.innerHTML = '<button type="button" disabled>—</button>'.repeat(4);
      return;
    }
    const d = new Date(data.date);
    slotLabel.textContent = formatDate(data.date);
    const dow = d.getDay();
    const times = dow === 6
      ? ['09:00','09:45','10:30','11:15']
      : ['09:00','10:00','11:00','13:00','14:00','15:00','16:00'];
    slotGrid.innerHTML = '';
    const unavail = Math.floor(Math.random() * 2) + 1;
    const unavailIdx = [Math.floor(Math.random() * times.length)];
    if (unavail > 1) unavailIdx.push((unavailIdx[0] + 2) % times.length);
    times.forEach((t, i) => {
      const b = document.createElement('button');
      b.type = 'button'; b.textContent = t;
      if (unavailIdx.includes(i)) b.disabled = true;
      if (data.time === t) b.classList.add('sel');
      b.addEventListener('click', () => {
        if (b.disabled) return;
        data.time = t;
        document.querySelectorAll('#slotGrid button').forEach(x => x.classList.remove('sel'));
        b.classList.add('sel');
        updateSidebar();
      });
      slotGrid.appendChild(b);
    });
  }

  function formatDate(iso) {
    const d = new Date(iso);
    const dows = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
    return dows[d.getDay()] + ' ' + d.getDate() + ' ' + months[d.getMonth()].slice(0,3) + ' ' + d.getFullYear();
  }

  document.getElementById('prevMonth').addEventListener('click', () => {
    viewDate.setMonth(viewDate.getMonth() - 1);
    renderCal();
  });
  document.getElementById('nextMonth').addEventListener('click', () => {
    viewDate.setMonth(viewDate.getMonth() + 1);
    renderCal();
  });

  // Live treatment selection
  form.querySelectorAll('input[name="treatment"]').forEach(r => {
    r.addEventListener('change', () => { data.treatment = r.value; updateSidebar(); });
  });

  renderCal();
  renderSlots();
  showStep(1);
})();
</script>

